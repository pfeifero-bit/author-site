# Email service. Pick one. Leave blank if you have not decided yet.
# Resend (recommended for sending + audience management).
# RESEND_FROM_EMAIL accepts "Display Name <hello@yourdomain>" format and
# must use a Resend-verified domain (see Resend dashboard > Domains).
RESEND_API_KEY=
RESEND_AUDIENCE_ID=
RESEND_FROM_EMAIL=Dale Nirvani Pfeifer <hello@aifundraisingfornonprofits.com>

# Or use Formspree as a no-backend fallback. Set the form endpoint URL.
# (used if RESEND_API_KEY is empty)
FORMSPREE_ENDPOINT=

# Inquiry routing. Speaking and Contact forms email this address via Resend.
# Also used as the Reply-To on the Chapter 1 email so direct replies land
# in a real human inbox.
INQUIRY_RECIPIENT=
FORMSPREE_INQUIRY_ENDPOINT=

# Chapter 1 PDF served from /public/downloads/chapter-1.pdf. The link in
# the auto-sent email is built from NEXT_PUBLIC_SITE_URL + that path.

# Public site URL used for sitemaps and OG tags.
NEXT_PUBLIC_SITE_URL=https://aifundraisingfornonprofits.com

# Pre-orders live? When set to "true", the retailer cluster (Amazon,
# Barnes & Noble, Bookshop.org, Audible) becomes visible across the site
# with clickable links. Default false until pre-order URLs are confirmed.
# This is exposed to the client because the Hero retailer row renders
# inside a client component.
NEXT_PUBLIC_PREORDERS_LIVE=false

# Analytics. Set ONE of these. Leave both blank to disable.
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
NEXT_PUBLIC_GA_ID=
